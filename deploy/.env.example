# docker-compose 环境变量示例。复制为 .env 后按需修改。
# cp deploy/.env.example deploy/.env

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=gva
MYSQL_PORT=13306

# JWT（生产必须改为强随机串）
JWT_SECRET=change-me-in-production

# 对外端口
WEB_PORT=80

# 镜像源前缀（受限网络用镜像加速）
# docker.io/library（默认，Docker Hub）| docker.m.daocloud.io/library（DaoCloud 加速）
REGISTRY=docker.io/library
