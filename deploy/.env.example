# docker-compose 环境变量示例。复制为 .env 后按需修改。
# cp deploy/.env.example deploy/.env

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=change-me-in-production
MYSQL_DATABASE=gva
# 宿主机映射端口；生产暴露给本机或内网即可，无需公网
MYSQL_PORT=13306

# ===== JWT（生产必须改为强随机串：openssl rand -hex 32）=====
JWT_SECRET=change-me-in-production

# ===== 对外端口 =====
# HTTP（TLS 由边界网关/Caddy/certbot 处理，此处保持 80）
WEB_PORT=80

# ===== 文档站（VitePress）=====
# base 路径：同域子路径 /docs/（默认）；独立域名部署用 /
DOCS_BASE=/docs/

# ===== 备份（db-backup 服务，需 --profile backup 启用）=====
BACKUP_INTERVAL=24h
KEEP_DAYS=7

# ===== 镜像/包源（受限网络用加速）=====
# docker.io/library（默认，Docker Hub）| docker.m.daocloud.io/library（DaoCloud 加速）
REGISTRY=docker.io/library
GOPROXY=https://goproxy.cn
NPM_REGISTRY=https://registry.npmmirror.com

# ===== 部署相关（DEPLOYMENT.md 详述）=====
# 域名（用于 nginx server_name / Let's Encrypt 签发）
# DOMAIN=example.com
# 是否启用 TLS（certbot 容器或边界网关处理）
# ENABLE_TLS=false
